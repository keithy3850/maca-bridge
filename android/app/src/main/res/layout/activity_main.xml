<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F6F9"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/maca_bridge_v1"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#1A1C1E"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="#D3E4FF"
        app:layout_constraintTop_toBottomOf="@id/tvHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:id="@+id/textView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PIN: 000000"
                android:textSize="32sp"
                android:textStyle="bold"
                android:textColor="#001C3B"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enter this on your Mac"
                android:textColor="#001C3B"
                android:layout_marginTop="4dp"
                android:alpha="0.7" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvStatusHeader"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="System Status"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#44474E"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@id/cardPin"
        app:layout_constraintStart_toStartOf="parent" />

    <LinearLayout
        android:id="@+id/layoutStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvStatusHeader">

        <!-- Notification Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_row"
            android:padding="16dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvNotificationStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Notification Listener: Enabled"
                android:textColor="#1A1C1E"
                android:layout_centerVertical="true" />

            <Button
                android:id="@+id/btnNotificationSettings"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fix"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>

        <!-- Photo Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_row"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvPhotoStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gallery Access: Granted"
                android:textColor="#1A1C1E"
                android:layout_centerVertical="true" />

            <Button
                android:id="@+id/btnPhotoSettings"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Grant"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true" />
        </RelativeLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSendClipboard"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Send Clipboard to Mac"
        android:layout_marginBottom="12dp"
        app:cornerRadius="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnTrackpad" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTrackpad"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Open Remote Trackpad"
        app:cornerRadius="16dp"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
